generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Producto {
  id            Int          @id @default(autoincrement())
  sku           String?      @unique
  marca         String
  descripcion   String
  ubicacion     String
  estante       String
  repisa        String
  cantidad      Float
  unidad        String
  observaciones String?

  movimientos   Movimiento[] // Relación con el historial
}

model Movimiento {
  id         Int       @id @default(autoincrement())
  tipo       String    // 'ingreso' o 'egreso'
  productoId Int
  cantidad   Float
  timestamp  DateTime  @default(now())

  producto   Producto  @relation(fields: [productoId], references: [id])
}
